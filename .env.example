# Where to POST the metrics. Use the same domain as the cluster-manager
# frontend; the path is `/api/metrics-ingest`.
INGEST_URL=https://cluster.gunnarstenzel.de/api/metrics-ingest

# Shared secret across all worker Pis. Must match WORKER_SECRET in the
# cluster-manager's .env on Uberspace.
WORKER_SECRET=replace-with-the-shared-worker-secret

# This Pi's name as registered in the cluster_pi table (case-insensitive).
# Has to match exactly one row in `cluster_pi.name`, or ingest returns 404.
NODE_NAME=pi-1
