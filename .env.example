################################################################################
# pi-health-metrics environment file.
#
# Lives at the repo root as `.env`. Only metrics.py reads it; this repo
# is standalone (does not share a .env with pi-cluster-worker or any
# other agents).
################################################################################


# ─── Identity ──────────────────────────────────────────────────────────────────
# This Pi's name as registered in the `cluster_pi` table on cluster-frontend
# (case-insensitive match against `cluster_pi.name`). Different per Pi.
NODE_NAME=REPLACE-WITH-THIS-PI-NAME


# ─── cluster-frontend metrics endpoint ─────────────────────────────────────────
# Fully-qualified URL of the metrics-ingest endpoint. Path is always
# /api/metrics-ingest under your cluster-frontend host.
INGEST_URL=https://cluster.gunnarstenzel.de/api/metrics-ingest


# ─── Auth ──────────────────────────────────────────────────────────────────────
# Shared secret. Must match `WORKER_SECRET` in cluster-frontend's root
# `.env` on Uberspace. Same secret used by pi-cluster-worker (the
# worker-side auth and the metrics-side auth are intentionally the same
# trust boundary).
WORKER_SECRET=replace-with-the-shared-worker-secret
